{
  "name": "song-recommender-memory",
  "version": "1.0.0",
  "description": "Song recommender with LangGraph memory persistence using LibSQL",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f postgres",
    "chat:leonardo": "node --experimental-strip-types --env-file .env src/index.ts --user leonardo",
    "chat:tamara": "node --experimental-strip-types --env-file .env src/index.ts --user tamara",
    "test": "node --experimental-strip-types --env-file .env --test tests/**/*.test.ts",
    "test:dev": "node --experimental-strip-types --env-file .env --test --watch tests/**/*.test.ts",
    "langgraph:serve": "npx @langchain/langgraph-cli dev"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "memory",
    "libsql",
    "sqlite",
    "song-recommender",
    "openrouter"
  ],
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.34",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@libsql/client": "^0.17.2",
    "@openrouter/sdk": "^0.9.11",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "knex": "^3.1.0",
    "langchain": "^1.2.35"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "@langchain/langgraph-cli": "^1.1.16"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
